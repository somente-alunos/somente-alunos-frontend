{
  "name": "somente-alunos-frontend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "tunnel": "%CD%/tunnel_local/cloudflared.exe tunnel --origincert=%USERPROFILE%\\.cloudflared\\credencial_somentealunos.vip\\cert.pem --url http://localhost:3000 run local_somentealunos_v1",
    "log-production": "npx wrangler tail somente-alunos-backend-production",
    "log-dev": "npx wrangler tail somente-alunos-backend-dev"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.11.3",
    "@nextui-org/react": "^2.4.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.2.10",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.553.0",
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.4",
    "typescript": "^5",
    "vercel": "^34.2.7",
    "wrangler": "^3.60.2"
  }
}
